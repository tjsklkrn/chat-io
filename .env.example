# Backend (Render / Railway)
PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/chat-io?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
USE_MEMORY_DB=false

# Comma-separated frontend URLs allowed by CORS and Socket.io
# Example: https://chat-io.vercel.app,http://localhost:3000
CLIENT_URL=https://your-frontend.vercel.app

# Frontend (Vercel) — prefix must be REACT_APP_
REACT_APP_API_URL=https://your-backend.onrender.com
REACT_APP_SOCKET_URL=https://your-backend.onrender.com
